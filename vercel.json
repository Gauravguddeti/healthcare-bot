{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/chat",              "dest": "api/index.py" },
    { "src": "/chat/sync",        "dest": "api/index.py" },
    { "src": "/upload",           "dest": "api/index.py" },
    { "src": "/languages",        "dest": "api/index.py" },
    { "src": "/health",           "dest": "api/index.py" },
    { "src": "/profile/(.+)",     "dest": "api/index.py" },
    { "src": "/history/(.+)",     "dest": "api/index.py" },
    { "src": "/",                 "dest": "frontend/index.html" },
    { "src": "/(.+\\.(js|css|png|jpg|jpeg|svg|ico|webp|woff2?))", "dest": "frontend/$1" },
    { "src": "/(.*)",             "dest": "frontend/index.html" }
  ]
}
